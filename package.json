{
  "name": "gemit-cli",
  "version": "2.1.1",
  "description": "CLI para sugerir commit/branch com IA, com config global e fluxo opcional de push",
  "main": "dist-secure/index.js",
  "bin": {
    "gemit": "dist-secure/index.js"
  },
  "files": [
    "dist-secure/**/*",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "gemit": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:secure": "npm run build && node scripts/build-secure.mjs",
    "prepack": "npm run build:secure",
    "start": "node dist/index.js",
    "start:secure": "node dist-secure/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "git",
    "commit",
    "branch",
    "cli",
    "ai",
    "conventional-commits"
  ],
  "author": "erick novaes56",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.34",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "javascript-obfuscator": "^5.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
